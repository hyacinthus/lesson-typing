{
  "id": "poetry-7",
  "title": "诗歌",
  "lessons": [
    {
      "id": "4db62be4-fa7f-4f88-85b0-099daadd27da",
      "title": "静夜思（李白）",
      "category": "思乡",
      "difficulty": 1,
      "order": 1,
      "content": "床前明月光，\n疑是地上霜。\n举头望明月，\n低头思故乡。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "13f3e75b-231f-4d9d-b6dc-145b567da393",
      "title": "春晓（孟浩然）",
      "category": "写景",
      "difficulty": 1,
      "order": 2,
      "content": "春眠不觉晓，\n处处闻啼鸟。\n夜来风雨声，\n花落知多少。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "36864636-eadd-47a1-b89d-46ab82b7be64",
      "title": "咏鹅（骆宾王）",
      "category": "咏物",
      "difficulty": 1,
      "order": 3,
      "content": "鹅，鹅，鹅，\n曲项向天歌。\n白毛浮绿水，\n红掌拨清波。",
      "characterCount": 27,
      "chineseCharCount": 18
    },
    {
      "id": "003bc9ca-d6cc-4fa1-ab41-1515a5a94c00",
      "title": "登鹳雀楼（王之涣）",
      "category": "哲理",
      "difficulty": 1,
      "order": 4,
      "content": "白日依山尽，\n黄河入海流。\n欲穷千里目，\n更上一层楼。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "a889043d-71cb-4b5b-8cd5-56e6e4ab35e6",
      "title": "春夜喜雨（杜甫）",
      "category": "写景",
      "difficulty": 3,
      "order": 5,
      "content": "好雨知时节，\n当春乃发生。\n随风潜入夜，\n润物细无声。\n野径云俱黑，\n江船火独明。\n晓看红湿处，\n花重锦官城。",
      "characterCount": 55,
      "chineseCharCount": 40
    },
    {
      "id": "614e81b0-3fc2-4b74-9c97-f483c31abf14",
      "title": "望庐山瀑布（李白）",
      "category": "写景",
      "difficulty": 2,
      "order": 6,
      "content": "日照香炉生紫烟，\n遥看瀑布挂前川。\n飞流直下三千尺，\n疑是银河落九天。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "b17ff9c5-7552-4438-a907-d9306eea5781",
      "title": "早发白帝城（李白）",
      "category": "写景",
      "difficulty": 2,
      "order": 7,
      "content": "朝辞白帝彩云间，\n千里江陵一日还。\n两岸猿声啼不住，\n轻舟已过万重山。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "abb334a1-7354-4bf4-a64c-0d387f942e7c",
      "title": "赠汪伦（李白）",
      "category": "送别",
      "difficulty": 2,
      "order": 8,
      "content": "李白乘舟将欲行，\n忽闻岸上踏歌声。\n桃花潭水深千尺，\n不及汪伦送我情。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "04f4d1ec-8692-4601-aa7a-6f0a908e6c42",
      "title": "望天门山（李白）",
      "category": "写景",
      "difficulty": 2,
      "order": 9,
      "content": "天门中断楚江开，\n碧水东流至此回。\n两岸青山相对出，\n孤帆一片日边来。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "04927846-9dea-4c9c-9448-bc9c2a25f890",
      "title": "绝句（杜甫）",
      "category": "写景",
      "difficulty": 2,
      "order": 10,
      "content": "两个黄鹂鸣翠柳，\n一行白鹭上青天。\n窗含西岭千秋雪，\n门泊东吴万里船。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "9fbcedbe-b7f8-42e7-aca1-cc0f11c03acf",
      "title": "江南（汉乐府）",
      "category": "写景",
      "difficulty": 1,
      "order": 11,
      "content": "江南可采莲，\n莲叶何田田。\n鱼戏莲叶间。\n鱼戏莲叶东，\n鱼戏莲叶西，\n鱼戏莲叶南，\n鱼戏莲叶北。",
      "characterCount": 48,
      "chineseCharCount": 35
    },
    {
      "id": "0105eecf-7c62-497e-883a-d66c418c66cd",
      "title": "悯农（李绅）",
      "category": "哲理",
      "difficulty": 1,
      "order": 12,
      "content": "锄禾日当午，\n汗滴禾下土。\n谁知盘中餐，\n粒粒皆辛苦。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "0340abc2-0afe-439e-ad8f-07e0dca9763b",
      "title": "悯农二（李绅）",
      "category": "哲理",
      "difficulty": 1,
      "order": 13,
      "content": "春种一粒粟，\n秋收万颗子。\n四海无闲田，\n农夫犹饿死。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "9bc76fbf-2c8a-4ee9-9ec6-9ee3218f221e",
      "title": "咏柳（贺知章）",
      "category": "咏物",
      "difficulty": 2,
      "order": 14,
      "content": "碧玉妆成一树高，\n万条垂下绿丝绦。\n不知细叶谁裁出，\n二月春风似剪刀。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "c5d9f661-f547-454b-b239-dbaea9cf0912",
      "title": "回乡偶书（贺知章）",
      "category": "思乡",
      "difficulty": 2,
      "order": 15,
      "content": "少小离家老大回，\n乡音无改鬓毛衰。\n儿童相见不相识，\n笑问客从何处来。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "d6f12771-7203-4f1e-b88d-50f5c8434228",
      "title": "凉州词（王之涣）",
      "category": "边塞",
      "difficulty": 2,
      "order": 16,
      "content": "黄河远上白云间，\n一片孤城万仞山。\n羌笛何须怨杨柳，\n春风不度玉门关。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "7a0b1a02-9734-4c8b-8ec7-906c3476b2ce",
      "title": "凉州词（王翰）",
      "category": "边塞",
      "difficulty": 2,
      "order": 17,
      "content": "葡萄美酒夜光杯，\n欲饮琵琶马上催。\n醉卧沙场君莫笑，\n古来征战几人回。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "4a33ba9d-0fa8-4fe3-97e5-3b81556e750e",
      "title": "出塞（王昌龄）",
      "category": "边塞",
      "difficulty": 2,
      "order": 18,
      "content": "秦时明月汉时关，\n万里长征人未还。\n但使龙城飞将在，\n不教胡马度阴山。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "663492de-d3f9-4169-8c04-1dd8a774d617",
      "title": "芙蓉楼送辛渐（王昌龄）",
      "category": "送别",
      "difficulty": 2,
      "order": 19,
      "content": "寒雨连江夜入吴，\n平明送客楚山孤。\n洛阳亲友如相问，\n一片冰心在玉壶。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "ffe4b8f5-9253-48a1-a5b7-af3622889db7",
      "title": "鹿柴（王维）",
      "category": "写景",
      "difficulty": 1,
      "order": 20,
      "content": "空山不见人，\n但闻人语响。\n返景入深林，\n复照青苔上。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "28ffdc59-f4cc-48a2-9855-f7ce56e56f6e",
      "title": "送元二使安西（王维）",
      "category": "送别",
      "difficulty": 2,
      "order": 21,
      "content": "渭城朝雨浥轻尘，\n客舍青青柳色新。\n劝君更尽一杯酒，\n西出阳关无故人。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "6445748b-6bc0-49c1-8233-219b945e5f2d",
      "title": "九月九日忆山东兄弟（王维）",
      "category": "思乡",
      "difficulty": 2,
      "order": 22,
      "content": "独在异乡为异客，\n每逢佳节倍思亲。\n遥知兄弟登高处，\n遍插茱萸少一人。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "9bc7e7c2-8da9-4807-af9f-a34584570b35",
      "title": "别董大（高适）",
      "category": "送别",
      "difficulty": 2,
      "order": 23,
      "content": "千里黄云白日曛，\n北风吹雁雪纷纷。\n莫愁前路无知己，\n天下谁人不识君。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "e7760854-9123-4dcd-9436-3c844314f50c",
      "title": "古朗月行（李白）",
      "category": "写景",
      "difficulty": 1,
      "order": 24,
      "content": "小时不识月，\n呼作白玉盘。\n又疑瑶台镜，\n飞在青云端。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "b86cdd3c-4182-4905-b58a-7198200d252b",
      "title": "望洞庭（刘禹锡）",
      "category": "写景",
      "difficulty": 2,
      "order": 25,
      "content": "湖光秋月两相和，\n潭面无风镜未磨。\n遥望洞庭山水翠，\n白银盘里一青螺。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "2ac0109c-b6b0-4f6e-bf1d-fe43181a5a02",
      "title": "忆江南（白居易）",
      "category": "思乡",
      "difficulty": 4,
      "order": 26,
      "content": "江南好，\n风景旧曾谙。\n日出江花红胜火，\n春来江水绿如蓝。\n能不忆江南？",
      "characterCount": 36,
      "chineseCharCount": 27
    },
    {
      "id": "1dd66d41-0807-4522-b032-d2c3d818c2e6",
      "title": "小池（杨万里）",
      "category": "写景",
      "difficulty": 2,
      "order": 27,
      "content": "泉眼无声惜细流，\n树阴照水爱晴柔。\n小荷才露尖尖角，\n早有蜻蜓立上头。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "112dbb63-0f5d-4e5c-bc9a-21c48f882eff",
      "title": "泊船瓜洲（王安石）",
      "category": "思乡",
      "difficulty": 2,
      "order": 28,
      "content": "京口瓜洲一水间，\n钟山只隔数重山。\n春风又绿江南岸，\n明月何时照我还。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "2d821d13-89ba-486f-a45f-55e58154ad02",
      "title": "游园不值（叶绍翁）",
      "category": "写景",
      "difficulty": 2,
      "order": 29,
      "content": "应怜屐齿印苍苔，\n小扣柴扉久不开。\n春色满园关不住，\n一枝红杏出墙来。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "130631a7-1f76-4f67-bc05-0063a4c58bbe",
      "title": "题西林壁（苏轼）",
      "category": "哲理",
      "difficulty": 2,
      "order": 30,
      "content": "横看成岭侧成峰，\n远近高低各不同。\n不识庐山真面目，\n只缘身在此山中。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "9c444c24-6c22-4c66-b743-33d2474c3bd0",
      "title": "饮湖上初晴后雨（苏轼）",
      "category": "写景",
      "difficulty": 2,
      "order": 31,
      "content": "水光潋滟晴方好，\n山色空蒙雨亦奇。\n欲把西湖比西子，\n淡妆浓抹总相宜。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "ec831db0-fb84-4f0e-8f54-017bf585ba79",
      "title": "惠崇春江晚景（苏轼）",
      "category": "写景",
      "difficulty": 2,
      "order": 32,
      "content": "竹外桃花三两枝，\n春江水暖鸭先知。\n蒌蒿满地芦芽短，\n正是河豚欲上时。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "b21644f0-9df9-4c94-b0c0-1f40964485d5",
      "title": "江畔独步寻花（杜甫）",
      "category": "写景",
      "difficulty": 2,
      "order": 33,
      "content": "黄师塔前江水东，\n春光懒困倚微风。\n桃花一簇开无主，\n可爱深红爱浅红。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "e36a1ce5-4730-4295-94d2-09f9fd37e19e",
      "title": "渔歌子（张志和）",
      "category": "田园",
      "difficulty": 4,
      "order": 34,
      "content": "西塞山前白鹭飞，\n桃花流水鳜鱼肥。\n青箬笠，绿蓑衣，\n斜风细雨不须归。",
      "characterCount": 35,
      "chineseCharCount": 27
    },
    {
      "id": "c14958f2-0c51-4d62-a60a-016ef21f4514",
      "title": "塞下曲（卢纶）",
      "category": "边塞",
      "difficulty": 2,
      "order": 35,
      "content": "月黑雁飞高，\n单于夜遁逃。\n欲将轻骑逐，\n大雪满弓刀。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "339670a0-5806-418d-8527-891dd93e051a",
      "title": "江雪（柳宗元）",
      "category": "写景",
      "difficulty": 1,
      "order": 36,
      "content": "千山鸟飞绝，\n万径人踪灭。\n孤舟蓑笠翁，\n独钓寒江雪。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "3a9055ff-39c0-494e-91ec-df07d4328d43",
      "title": "夜宿山寺（李白）",
      "category": "写景",
      "difficulty": 1,
      "order": 37,
      "content": "危楼高百尺，\n手可摘星辰。\n不敢高声语，\n恐惊天上人。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "88fb8202-72f5-43c5-a87c-ea70802a62cf",
      "title": "梅花（王安石）",
      "category": "咏物",
      "difficulty": 1,
      "order": 38,
      "content": "墙角数枝梅，\n凌寒独自开。\n遥知不是雪，\n为有暗香来。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "b5425123-01dc-4749-ab2d-6dc66d00164d",
      "title": "元日（王安石）",
      "category": "节日",
      "difficulty": 2,
      "order": 39,
      "content": "爆竹声中一岁除，\n春风送暖入屠苏。\n千门万户曈曈日，\n总把新桃换旧符。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "376459f6-9b15-41cd-8575-8319e536ca93",
      "title": "示儿（陆游）",
      "category": "爱国",
      "difficulty": 1,
      "order": 40,
      "content": "死去元知万事空，\n但悲不见九州同。\n王师北定中原日，\n家祭无忘告乃翁。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "955cd229-ec3c-4175-9e40-30484d57b32b",
      "title": "己亥杂诗（龚自珍）",
      "category": "爱国",
      "difficulty": 2,
      "order": 41,
      "content": "九州生气恃风雷，\n万马齐喑究可哀。\n我劝天公重抖擞，\n不拘一格降人才。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "530639c4-a249-4ca1-a912-88d92f08c913",
      "title": "石灰吟（于谦）",
      "category": "咏物",
      "difficulty": 2,
      "order": 42,
      "content": "千锤万凿出深山，\n烈火焚烧若等闲。\n粉骨碎身浑不怕，\n要留清白在人间。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "7188ebc0-48b8-4ace-9dde-b2984deaa191",
      "title": "竹石（郑燮）",
      "category": "咏物",
      "difficulty": 2,
      "order": 43,
      "content": "咬定青山不放松，\n立根原在破岩中。\n千磨万击还坚劲，\n任尔东西南北风。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "2f42fd9f-eb44-4a14-ba34-db2787a6f15c",
      "title": "所见（袁枚）",
      "category": "田园",
      "difficulty": 2,
      "order": 44,
      "content": "牧童骑黄牛，\n歌声振林樾。\n意欲捕鸣蝉，\n忽然闭口立。",
      "characterCount": 27,
      "chineseCharCount": 20
    },
    {
      "id": "160620f3-dcc6-43b1-90b5-cf33dd0460e8",
      "title": "村居（高鼎）",
      "category": "田园",
      "difficulty": 2,
      "order": 45,
      "content": "草长莺飞二月天，\n拂堤杨柳醉春烟。\n儿童散学归来早，\n忙趁东风放纸鸢。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "7a14f5ed-25d7-48e7-ba66-a0b0f0a14915",
      "title": "清明（杜牧）",
      "category": "节日",
      "difficulty": 2,
      "order": 46,
      "content": "清明时节雨纷纷，\n路上行人欲断魂。\n借问酒家何处有，\n牧童遥指杏花村。",
      "characterCount": 35,
      "chineseCharCount": 28
    },
    {
      "id": "5697cbad-5a1e-4957-9e98-1db38a5a1abd",
      "title": "游子吟（孟郊）",
      "category": "抒情",
      "difficulty": 1,
      "order": 47,
